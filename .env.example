# --- Telegram ---
TELEGRAM_BOT_TOKEN=
TELEGRAM_WEBHOOK_SECRET=
TELEGRAM_BOT_USERNAME=

# --- Supabase ---
NEXT_PUBLIC_SUPABASE_URL=
# Publishable key (sb_publishable_..., or legacy `anon` key on older projects).
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Secret key (sb_secret_..., or legacy `service_role` key on older projects).
SUPABASE_SERVICE_ROLE_KEY=
# JWK JSON of the ES256 (or RS256) PRIVATE signing key. Generate with:
#   pnpm exec supabase gen signing-key --algorithm ES256
# Then import the public half into Supabase Dashboard → JWT Keys → standby → rotate.
# Paste the entire one-line JSON object as the value (incl. `d`, `x`, `y`, `kid`, `alg`).
SUPABASE_JWT_PRIVATE_KEY=
# Session Pooler URL (host: aws-0-<region>.pooler.supabase.com, port 5432).
# Used at deploy time by `supabase db push` to apply migrations on Vercel.
# IMPORTANT: Vercel build runners are IPv4-only, so the IPv6-by-default Direct
# connection (db.<ref>.supabase.co:5432) won't work without the IPv4 add-on.
# Don't use the Transaction Pooler (port 6543) either — it doesn't support DDL.
SUPABASE_DB_URL=

# --- App ---
APP_BASE_URL=http://localhost:3000
# Comma-separated list of Telegram numeric user ids auto-promoted to `admin`
# on first webhook hit. Single id is fine (e.g. `12345`), or many (`12345,67890`).
BOOTSTRAP_ADMIN_TG_USER_IDS=
DAILY_QUOTA_SECONDS=300
CLAIM_TTL_MINUTES=15
DEFAULT_TZ=Asia/Jerusalem

# --- Cron ---
CRON_SECRET=
# Upstash QStash API token (Console → QStash → API Keys). Used by
# `scripts/sync-qstash.mjs` at deploy time to create the cron schedule
# automatically. Optional — if unset, set up the schedule manually per
# INFRA.md §5.
QSTASH_TOKEN=
# Optional QStash API base URL. Defaults to the global endpoint
# https://qstash.upstash.io. Set this only if your QStash account is
# region-scoped (e.g. https://qstash-us-east-1.upstash.io).
QSTASH_URL=
