{
  "name": "hebtutbot",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "vercel-build": "node scripts/db-push.mjs && node scripts/sync-qstash.mjs && next build",
    "db:push": "supabase db push --db-url \"$SUPABASE_DB_URL\" --include-all",
    "start": "next start",
    "lint": "next lint",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "db:types": "supabase gen types typescript --linked --schema public > src/types/database.ts"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.45.4",
    "date-fns": "^3.6.0",
    "date-fns-tz": "^3.1.3",
    "grammy": "^1.30.0",
    "jose": "^5.9.6",
    "next": "^14.2.20",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^20.16.10",
    "@types/react": "^18.3.11",
    "@types/react-dom": "^18.3.0",
    "autoprefixer": "^10.4.20",
    "eslint": "^8.57.1",
    "eslint-config-next": "^14.2.20",
    "postcss": "^8.4.47",
    "postgres": "^3.4.9",
    "prettier": "^3.3.3",
    "supabase": "^2.95.3",
    "tailwindcss": "^3.4.13",
    "typescript": "^5.6.2",
    "vitest": "^2.1.2"
  },
  "packageManager": "pnpm@10.33.0",
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "supabase",
      "unrs-resolver"
    ]
  }
}
